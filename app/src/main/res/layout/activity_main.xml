<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/iv_welcome_kitty"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/welcome_kitty"
        app:layout_constraintBottom_toTopOf="@id/tv_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="How are you feeling today?"
        android:textColor="@color/cozy_plum"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.55" />

    <LinearLayout
        android:id="@+id/layout_mood_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_good"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="🌸 Good"
            android:textAllCaps="false"
            android:textColor="@color/cozy_plum"
            android:backgroundTint="@color/pastel_pink" />

        <Button
            android:id="@+id/btn_neutral"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="☁️ Okay"
            android:textAllCaps="false"
            android:textColor="@color/cozy_plum"
            android:backgroundTint="@color/pastel_pink" />

        <Button
            android:id="@+id/btn_bad"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="🌧️ Down"
            android:textAllCaps="false"
            android:textColor="@color/cozy_plum"
            android:backgroundTint="@color/pastel_pink" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_view_history"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#D8B4F8"
        android:text="📜 View Past Reflections"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/layout_mood_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_view_analytics"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#B3A2C7"
        android:text="📊 View Mood Analytics"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btn_view_history"
        app:layout_constraintStart_toStartOf="@id/btn_view_history"
        app:layout_constraintEnd_toEndOf="@id/btn_view_history" />
</androidx.constraintlayout.widget.ConstraintLayout>