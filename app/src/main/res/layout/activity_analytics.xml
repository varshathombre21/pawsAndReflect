<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5E4"
    android:padding="24dp">

    <Button
        android:id="@+id/btn_analytics_back"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:backgroundTint="#B3A2C7"
        android:text="⬅ Back"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_analytics_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Mood Journey 📊"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#654E92"
        app:layout_constraintTop_toBottomOf="@id/btn_analytics_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_analytics_title"
        android:layout_marginTop="20dp"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_total_reflections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Reflections: 0"
                android:textSize="18sp"
                android:textColor="#7F669D"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Every entry helps you understand yourself better 🐾"
                android:textSize="12sp"
                android:textColor="#B3A2C7"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/layout_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/card_total"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/tv_good_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌸 Good Mood Days: 0%"
            android:textColor="#654E92"
            android:textStyle="bold"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/progress_good"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#FFB4B4"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tv_okay_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💜 Okay Mood Days: 0%"
            android:textColor="#654E92"
            android:textStyle="bold"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/progress_okay"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#B3A2C7"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tv_down_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁️ Down Mood Days: 0%"
            android:textColor="#654E92"
            android:textStyle="bold"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/progress_down"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#8EA7E9"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>